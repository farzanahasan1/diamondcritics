<tr><td>Oval</td><td>8.5mm × 6.0mm</td><td>40.1mm²</td><td>+21%</td></tr>
<tr><td>Marquise (2.00:1)</td><td>11.0mm × 5.5mm</td><td>47.5mm²</td><td>+43%</td></tr>
<tr><td>Pear</td><td>8.5mm × 5.8mm</td><td>38.7mm²</td><td>+17%</td></tr>
