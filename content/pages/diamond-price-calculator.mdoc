-search"; // 2. Calculate Carat Range (+/- 0.05ct) let minCarat = Math.max(0.3, window.v10State.carat - 0.05).toFixed(2); let maxCarat = (window.v10State.carat + 0.05).toFixed(2); // 3. Map Cut to Blue Nile's terminology let cutMapping = { 'excellent': 'Ideal', 'vgood': 'Very+Good', 'good': 'Good' }; let mappedCut = cutMapping; // 4. Map Shape (Appends '-cut' to the key) let mappedShape = window.v10State.shape + "-cut"; // 5. Construct the final URL let affParams = "a\_aid=69d7c31a91b8d&a\_cid=55e51e63&chan=Calculator"; let finalUrl = \`${baseUrl}?CaratFrom=${minCarat}&CaratTo=${maxCarat}&Color=${window.v10State.color}&Cut=${mappedCut}&Shape=${mappedShape}&Clarity=${window.v10State.clarity}&${affParams}\`; // 6. Apply to the button document.getElementById('v10-aff-link').href = finalUrl; // ----------------------------------------- document.getElementById('v10-output').scrollIntoView({ behavior: 'smooth', block: 'center' }); }; #dc-auditor-v10 { max-width: 1000px; margin: 40px auto; padding: 60px 20px; background: #fff; font-family: 'Poppins', sans-serif; text-align: center; } .v10-header h2 { font-family: 'Marcellus', serif; font-size: clamp(32px, 5vw, 48px); margin: 0; } .v10-eyebrow { font-size: 10px; text-transform: uppercase; letter-spacing: 5px; font-weight: 700; color: #aaa; display: block; margin-bottom: 10px; } .v10-section-label { display: block; font-weight: 700; font-size: 12px; text-transform: uppercase; letter-spacing: 2px; color: #888; margin: 40px 0 20px; } .v10-grid { display: flex; flex-wrap: wrap; justify-content: center; gap: 10px; } .v10-opt { background: #fff; border: 1px solid #eee; padding: 12px 25px; cursor: pointer; font-size: 13px; font-weight: 600; transition: 0.3s; } .v10-opt.active { background: #000; color: #fff; border-color: #000; } /\* 10 SHAPES \*/ .v10-shape-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 15px; max-width: 600px; margin: 0 auto; } .v10-shape-card { border: 1px solid #eee; padding: 15px; cursor: po